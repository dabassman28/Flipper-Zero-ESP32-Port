App(
    appid="usb_rpc",
    name="UsbRpcSrv",
    apptype=FlipperAppType.SERVICE,
    entry_point="usb_rpc_srv",
    # Generous stack: this thread calls furi_hal_usb_composite_install
    # which on ESP32-S3 runs the deep TinyUSB / esp_tinyusb init chain.
    stack_size=8192,
    order=20,
    sources=["usb_rpc.c"],
)
